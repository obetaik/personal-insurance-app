[run]
source = .
omit = 
    tests/*
    run_tests.py
    venv/*
    */site-packages/*
    */dist-packages/*
    __pycache__/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if self.debug:
    if __name__ == .__main__.:
    raise AssertionError
    raise NotImplementedError
    if 0:
    if False:
    if True: